<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- AUDIT CYCLE FORM VIEW -->

    <record id="audit_cycle_form" model="ir.ui.view">
        <field name="name">asset.audit.cycle.form</field>
        <field name="model">asset.audit.cycle</field>
        <field name="arch" type="xml">
            <form string="Audit Cycle">
                <header>
                    <button name="action_start" string="Start Audit"
                        type="object" class="btn-primary"
                        invisible="state != 'draft'"
                        groups="asset_management.group_asset_manager"/>
                    <button name="action_close" string="Close Audit Cycle"
                        type="object" class="btn-success"
                        invisible="state != 'in_progress' or not line_ids_completed"
                        groups="asset_management.group_asset_manager"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <field name="reference" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="scope_type"/>
                            <field name="department_id" options="{'no_create': True}"
                                invisible="scope_type != 'department'"
                                required="scope_type == 'department'"/>
                            <field name="location"
                                invisible="scope_type != 'location'"
                                required="scope_type == 'location'"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="auditor_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group>
                        <div class="o_stat_points">
                            <div class="o_stat_item">
                                <field name="total_lines" readonly="1"/>
                                <span class="o_stat_text">Total Lines</span>
                            </div>
                            <div class="o_stat_item text-success">
                                <field name="verified_count" readonly="1"/>
                                <span class="o_stat_text">Verified</span>
                            </div>
                            <div class="o_stat_item text-danger">
                                <field name="missing_count" readonly="1"/>
                                <span class="o_stat_text">Missing</span>
                            </div>
                            <div class="o_stat_item text-warning">
                                <field name="damaged_count" readonly="1"/>
                                <span class="o_stat_text">Damaged</span>
                            </div>
                        </div>
                    </group>
                    <notebook>
                        <page string="Audit Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="asset_id" options="{'no_create': True}" readonly="1"/>
                                    <field name="asset_tag" readonly="1"/>
                                    <field name="result" widget="radio"
                                        readonly="cycle_state != 'in_progress'"/>
                                    <field name="notes" readonly="cycle_state != 'in_progress'"/>
                                    <field name="auditor_id" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,in_progress,closed" readonly="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- AUDIT LINE LIST VIEW -->

    <record id="audit_line_list" model="ir.ui.view">
        <field name="name">asset.audit.line.list</field>
        <field name="model">asset.audit.line</field>
        <field name="arch" type="xml">
            <list string="Audit Lines" editable="bottom">
                <field name="cycle_id" readonly="1" optional="hide"/>
                <field name="asset_id" options="{'no_create': True}" readonly="1"/>
                <field name="asset_tag" readonly="1"/>
                <field name="result" widget="radio" readonly="cycle_state != 'in_progress'"/>
                <field name="notes" readonly="cycle_state != 'in_progress'"/>
                <field name="auditor_id" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="audit_line_search" model="ir.ui.view">
        <field name="name">asset.audit.line.search</field>
        <field name="model">asset.audit.line</field>
        <field name="arch" type="xml">
            <search string="Search Audit Lines">
                <field name="asset_id"/>
                <field name="asset_tag"/>
                <field name="auditor_id"/>
                <separator/>
                <filter name="filter_verified" string="Verified" domain="[('result', '=', 'verified')]"/>
                <filter name="filter_missing" string="Missing" domain="[('result', '=', 'missing')]"/>
                <filter name="filter_damaged" string="Damaged" domain="[('result', '=', 'damaged')]"/>
                <group name="group_by">
                    <filter name="group_result" string="Result" context="{'group_by': 'result'}"/>
                    <filter name="group_cycle" string="Audit Cycle" context="{'group_by': 'cycle_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- AUDIT CYCLE LIST VIEW -->

    <record id="audit_cycle_list" model="ir.ui.view">
        <field name="name">asset.audit.cycle.list</field>
        <field name="model">asset.audit.cycle</field>
        <field name="arch" type="xml">
            <list string="Audit Cycles">
                <field name="reference"/>
                <field name="name"/>
                <field name="scope_type"/>
                <field name="department_id"/>
                <field name="location"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="total_lines" readonly="1"/>
                <field name="discrepancy_count" readonly="1"/>
                <field name="state" widget="badge"
                    decoration-muted="state == 'draft'"
                    decoration-info="state == 'in_progress'"
                    decoration-success="state == 'closed'"/>
            </list>
        </field>
    </record>

    <!-- AUDIT CYCLE SEARCH VIEW -->

    <record id="audit_cycle_search" model="ir.ui.view">
        <field name="name">asset.audit.cycle.search</field>
        <field name="model">asset.audit.cycle</field>
        <field name="arch" type="xml">
            <search string="Search Audit Cycles">
                <field name="name"/>
                <field name="reference"/>
                <separator/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                <group name="group_by">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- AUDIT ACTIONS -->

    <record id="audit_cycle_action" model="ir.actions.act_window">
        <field name="name">Audit Cycles</field>
        <field name="res_model">asset.audit.cycle</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="audit_cycle_search"/>
    </record>

    <record id="audit_line_action" model="ir.actions.act_window">
        <field name="name">Audit Lines</field>
        <field name="res_model">asset.audit.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="audit_line_search"/>
    </record>

</odoo>
