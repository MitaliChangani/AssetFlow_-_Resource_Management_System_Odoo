<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- ASSET PIVOT VIEW                                              -->
    <!-- ============================================================ -->

    <record id="asset_pivot" model="ir.ui.view">
        <field name="name">asset.asset.pivot</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <pivot string="Asset Analysis">
                <field name="category_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- ASSET GRAPH VIEW                                              -->
    <!-- ============================================================ -->

    <record id="asset_graph" model="ir.ui.view">
        <field name="name">asset.asset.graph</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <graph string="Asset Distribution" type="bar" sample="1">
                <field name="category_id"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- ASSET REPORT ACTION                                           -->
    <!-- ============================================================ -->

    <record id="asset_report_action" model="ir.actions.act_window">
        <field name="name">Asset Report</field>
        <field name="res_model">asset.asset</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{
            'search_default_group_category': 1,
        }</field>
    </record>

    <!-- ============================================================ -->
    <!-- ALLOCATION PIVOT VIEW                                         -->
    <!-- ============================================================ -->

    <record id="allocation_pivot" model="ir.ui.view">
        <field name="name">asset.allocation.pivot</field>
        <field name="model">asset.allocation</field>
        <field name="arch" type="xml">
            <pivot string="Allocation Analysis">
                <field name="department_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="allocation_graph" model="ir.ui.view">
        <field name="name">asset.allocation.graph</field>
        <field name="model">asset.allocation</field>
        <field name="arch" type="xml">
            <graph string="Allocation Trends" type="line" sample="1">
                <field name="allocated_date" type="row"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <record id="allocation_report_action" model="ir.actions.act_window">
        <field name="name">Allocation Report</field>
        <field name="res_model">asset.allocation</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{
            'search_default_group_department': 1,
        }</field>
    </record>

    <!-- ============================================================ -->
    <!-- MAINTENANCE PIVOT VIEW                                        -->
    <!-- ============================================================ -->

    <record id="maintenance_pivot" model="ir.ui.view">
        <field name="name">am.maintenance.request.pivot</field>
        <field name="model">am.maintenance.request</field>
        <field name="arch" type="xml">
            <pivot string="Maintenance Analysis">
                <field name="asset_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="maintenance_graph" model="ir.ui.view">
        <field name="name">am.maintenance.request.graph</field>
        <field name="model">am.maintenance.request</field>
        <field name="arch" type="xml">
            <graph string="Maintenance by Priority" type="bar" sample="1">
                <field name="priority" type="row"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <record id="maintenance_report_action" model="ir.actions.act_window">
        <field name="name">Maintenance Report</field>
        <field name="res_model">am.maintenance.request</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

    <!-- ============================================================ -->
    <!-- BOOKING PIVOT VIEW (Heatmap substitute via pivot)            -->
    <!-- ============================================================ -->

    <record id="booking_pivot" model="ir.ui.view">
        <field name="name">resource.booking.pivot</field>
        <field name="model">resource.booking</field>
        <field name="arch" type="xml">
            <pivot string="Booking Analysis">
                <field name="asset_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="booking_graph" model="ir.ui.view">
        <field name="name">resource.booking.graph</field>
        <field name="model">resource.booking</field>
        <field name="arch" type="xml">
            <graph string="Bookings by Resource" type="bar" sample="1">
                <field name="asset_id" type="row"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <record id="booking_report_action" model="ir.actions.act_window">
        <field name="name">Booking Report</field>
        <field name="res_model">resource.booking</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

</odoo>
