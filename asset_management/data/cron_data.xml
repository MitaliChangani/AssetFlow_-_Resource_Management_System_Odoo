<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Mark overdue allocations daily -->
        <record id="cron_mark_overdue" model="ir.cron">
            <field name="name">Asset Management: Mark Overdue Allocations</field>
            <field name="model_id" ref="model_asset_allocation"/>
            <field name="state">code</field>
            <field name="code">model._cron_mark_overdue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">1</field>
        </record>

        <!-- Update booking states (upcoming → ongoing → completed) -->
        <record id="cron_update_booking_states" model="ir.cron">
            <field name="name">Asset Management: Update Booking States</field>
            <field name="model_id" ref="model_resource_booking"/>
            <field name="state">code</field>
            <field name="code">model._cron_update_booking_states()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active">1</field>
        </record>

        <!-- Booking reminders (30 min before start) -->
        <record id="cron_booking_reminders" model="ir.cron">
            <field name="name">Asset Management: Send Booking Reminders</field>
            <field name="model_id" ref="model_resource_booking"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_reminders()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active">1</field>
        </record>

    </data>
</odoo>
